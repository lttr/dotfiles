{
  "fileSuggestion": {
    "type": "command",
    "command": "~/dotfiles/claude/scripts/file-suggestion.sh"
  },
  "permissions": {
    "allow": [
      "Bash(basename:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(eslint:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(gh --help)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh search:*)",
      "Bash(gh status:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rebase:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git submodule:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(mkdir:*)",
      "Bash(npm:*)",
      "Bash(npx eslint:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx stylelint:*)",
      "Bash(vp:*)",
      "Bash(pgrep:*)",
      "Bash(pkill:*)",
      "Bash(pnpm:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(xargs kill -9)",
      "Bash(xargs rg:*)",
      "Edit(/.claude/skills/**)",
      "Write(/.claude/skills/**)",
      "WebSearch",
      "mcp__pencil"
    ],
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=* of=/dev/*:*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/home/lukas/code/claude-marketplace/"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/context-agents-md.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/reset-timer-on-clear.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/format-code.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/copy-plan-to-aiwork.ts",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/log-slash-command.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/damage-control/bash-tool-damage-control.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/damage-control/file-tool-damage-control.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/log-skill-usage.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/auto-allow-claude-paths.ts",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/dotfiles/claude/scripts/status-line.js",
    "padding": 0
  },
  "enabledPlugins": {
    "cc@lttr-claude-marketplace": true,
    "typescript-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "notifications_disabled",
  "showTurnDuration": false,
  "remoteControlAtStartup": false,
  "terminalProgressBarEnabled": false
}
