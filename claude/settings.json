{
  "fileSuggestion": {
    "type": "command",
    "command": "~/dotfiles/claude/scripts/file-suggestion.sh"
  },
  "skillListingBudgetFraction": 0.005,
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=* of=/dev/*:*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "skillOverrides": {
    "deep-research": "name-only",
    "fewer-permission-prompts": "off"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/context-agents-md.sh"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/reset-timer-on-clear.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/format-code.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/copy-plan-to-aiwork.ts",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/damage-control/record-approved-packages.ts",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/log-slash-command.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/damage-control/bash-tool-damage-control.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/damage-control/file-tool-damage-control.ts",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/log-skill-usage.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/hooks/auto-allow-claude-paths.ts",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/dotfiles/claude/scripts/status-line.js",
    "padding": 0
  },
  "enabledPlugins": {
    "cc@lttr-claude-marketplace": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "outputStyle": "default",
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "verbose": false,
  "preferredNotifChannel": "notifications_disabled",
  "autoCompactEnabled": false,
  "showTurnDuration": false,
  "terminalProgressBarEnabled": false,
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "maxSkillDescriptionChars": 250,
  "awaySummaryEnabled": false
}
